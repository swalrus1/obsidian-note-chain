{
	"compilerOptions": {
		"module": "CommonJS",
		"target": "ES2020",
		"lib": ["ES2020"],
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "../core/**/*.ts"]
}
